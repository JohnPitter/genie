# ── Required ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional ─────────────────────────────────────────────────────────────────
# LLM model used by the agent (default: qwen/qwen3-next-80b-a3b-instruct:free)
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Optional fallback model — used automatically by OpenRouter if the primary
# model fails (rate limit, 5xx, unavailable). Leave empty to disable.
OPENROUTER_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# HTTP port for the Go API server
PORT=5858

# Path to the SQLite database file
DB_PATH=./genie.db

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# TTL for cached news per category (minutes)
NEWS_CACHE_TTL_MINUTES=30

# TTL for cached B3 quotes (seconds)
QUOTE_CACHE_TTL_SECONDS=60

# Optional brapi.dev token — increases rate limits
BRAPI_TOKEN=

# ── Frontend (SvelteKit PUBLIC_ vars are exposed to the browser) ──────────────
# Base URL of the Go API. Leave empty to use same origin (recommended for prod).
PUBLIC_API_BASE_URL=""
