# ── Required ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional ─────────────────────────────────────────────────────────────────
# LLM model used by the agent. Chosen via benchmark (src/scripts/bench-models.ts)
# entre modelos :free que suportam tool-calling no OpenRouter.
# Top 3 FREE por TTFT no contexto Genie: gpt-oss-120b (~2s), gpt-oss-20b (~1.7s),
# nemotron-3-nano-30b (~1.8s). O Nemotron 120B ficou ~10x mais lento (~18s).
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Fallbacks (lista separada por vírgula) — OpenRouter tenta o próximo
# automaticamente se o primário falhar (429/5xx/unavailable).
# ATENÇÃO: OpenRouter aceita no máximo 2 fallbacks (primário + 2 = 3 itens).
OPENROUTER_MODEL_FALLBACK=openai/gpt-oss-20b:free,inclusionai/ling-2.6-flash:free

# HTTP port for the Go API server
PORT=5858

# Path to the SQLite database file
DB_PATH=./genie.db

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# TTL for cached news per category (minutes)
NEWS_CACHE_TTL_MINUTES=30

# TTL for cached B3 quotes (seconds)
QUOTE_CACHE_TTL_SECONDS=60

# Optional brapi.dev token — increases rate limits
BRAPI_TOKEN=

# ── Frontend (SvelteKit PUBLIC_ vars are exposed to the browser) ──────────────
# Base URL of the Go API. Leave empty to use same origin (recommended for prod).
PUBLIC_API_BASE_URL=""
