{
  "name": "@genie/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --out-dir dist --sourcemap --clean",
    "start": "node dist/main.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@genie/shared": "workspace:*",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.9.1",
    "cheerio": "^1.0.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "fastify": "^5.3.2",
    "jsdom": "^26.1.0",
    "openai": "^4.97.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "turndown": "^7.2.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.14.1",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^3.1.2",
    "drizzle-kit": "^0.30.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
